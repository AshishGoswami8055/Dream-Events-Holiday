# Copy to .env.local for local development.
# In Vercel: Project → Settings → Environment Variables → add each key below.

# App (required on Vercel — use your production URL, e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Dream Events & Holiday"

# MongoDB Atlas (required)
# Use mongodb+srv://... on Vercel, or direct shard URL if SRV fails locally
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dream-events-holiday?retryWrites=true&w=majority

# NextAuth (required)
AUTH_SECRET=generate-a-random-string-at-least-32-characters-long
AUTH_URL=http://localhost:3000

# Admin seed — only needed when running npm run seed locally
ADMIN_EMAIL=admin@dreamevents.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin

# Cloudinary (required for admin image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Email — optional (Gmail SMTP recommended)
# When configured, admin gets instant email for every package inquiry & contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dreamevents.holidays@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Dream Event & Holidays <dreamevents.holidays@gmail.com>"
ADMIN_NOTIFICATION_EMAIL=dreamevents.holidays@gmail.com

# WhatsApp — optional
NEXT_PUBLIC_WHATSAPP_NUMBER=919023612162
